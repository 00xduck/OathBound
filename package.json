{
  "name": "oathbound",
  "version": "0.5.5",
  "description": "OathBound",
  "main": "main.js",
  "scripts": {
    "build": "cd public && tsc",
    "buildStart": "npm run build && npm run start",
    "start": "electron .",
    "dist:windows": "electron-builder",
    "dist:linux": "electron-builder --linux deb"
  },
  "build": {
    "appId": "oathbound",
    "productName": "OathBound",
    "beforeBuild": null,
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico"
    },
    "linux": {
      "target": [{ "target": "deb", "arch": ["x64"] }],
      "icon": "build/icons",
      "category": "Game",
      "maintainer": "Dein Name <deine@email.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": {
    "name": "Duckar",
    "email": "bojat43900@lohinja.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.2.0"
  }
}
